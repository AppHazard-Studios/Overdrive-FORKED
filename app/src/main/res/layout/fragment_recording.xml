<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_base"
    android:orientation="vertical">

    <!-- Tab Layout for Controls / Library -->
    <!-- Note: Tabs are created dynamically by TabLayoutMediator - do NOT add TabItems here -->
    <com.google.android.material.tabs.TabLayout
        android:id="@+id/tabLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/bg_surface"
        app:tabIndicatorColor="@color/brand_primary"
        app:tabIndicatorHeight="3dp"
        app:tabSelectedTextColor="@color/brand_primary"
        app:tabTextColor="@color/text_secondary"
        app:tabRippleColor="@color/brand_cyan_glow"
        app:tabMode="fixed"
        app:tabGravity="fill" />

    <androidx.viewpager2.widget.ViewPager2
        android:id="@+id/viewPager"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

</LinearLayout>
