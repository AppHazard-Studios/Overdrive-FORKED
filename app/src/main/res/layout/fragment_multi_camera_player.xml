<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <!-- GL view fills the entire screen; overlays sit on top -->
    <com.overdrive.app.ui.view.MultiCameraGLView
        android:id="@+id/glView"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!--
        Camera column overlay — mirrors the GL quad positions exactly:
          Left 74%: large primary area. Tappable to toggle controls.
          Right 26%: four equal rows, one per camera, all tappable.
        The selected camera row shows a brand-colour left border.
        Always visible so the camera thumbnails are always accessible.
    -->
    <LinearLayout
        android:id="@+id/cameraOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="horizontal">

        <!-- Large primary area: tap here to toggle playback controls -->
        <View
            android:id="@+id/primaryTapTarget"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="74" />

        <!-- Right column: all four cameras, each tappable -->
        <LinearLayout
            android:id="@+id/cameraColumn"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="26"
            android:orientation="vertical">

            <FrameLayout
                android:id="@+id/camCellFront"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:foreground="?attr/selectableItemBackground">

                <View
                    android:id="@+id/camActiveFront"
                    android:layout_width="3dp"
                    android:layout_height="match_parent"
                    android:layout_gravity="start"
                    android:background="@color/brand_primary"
                    android:visibility="gone" />

                <TextView
                    android:id="@+id/tvCamLabelFront"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="bottom|center_horizontal"
                    android:layout_margin="4dp"
                    android:paddingHorizontal="4dp"
                    android:paddingVertical="1dp"
                    android:background="#66000000"
                    android:textColor="#CCFFFFFF"
                    android:textSize="9sp"
                    android:fontFamily="sans-serif-medium"
                    android:text="FRONT" />
            </FrameLayout>

            <FrameLayout
                android:id="@+id/camCellRight"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:foreground="?attr/selectableItemBackground">

                <View
                    android:id="@+id/camActiveRight"
                    android:layout_width="3dp"
                    android:layout_height="match_parent"
                    android:layout_gravity="start"
                    android:background="@color/brand_primary"
                    android:visibility="gone" />

                <TextView
                    android:id="@+id/tvCamLabelRight"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="bottom|center_horizontal"
                    android:layout_margin="4dp"
                    android:paddingHorizontal="4dp"
                    android:paddingVertical="1dp"
                    android:background="#66000000"
                    android:textColor="#CCFFFFFF"
                    android:textSize="9sp"
                    android:fontFamily="sans-serif-medium"
                    android:text="RIGHT" />
            </FrameLayout>

            <FrameLayout
                android:id="@+id/camCellRear"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:foreground="?attr/selectableItemBackground">

                <View
                    android:id="@+id/camActiveRear"
                    android:layout_width="3dp"
                    android:layout_height="match_parent"
                    android:layout_gravity="start"
                    android:background="@color/brand_primary"
                    android:visibility="gone" />

                <TextView
                    android:id="@+id/tvCamLabelRear"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="bottom|center_horizontal"
                    android:layout_margin="4dp"
                    android:paddingHorizontal="4dp"
                    android:paddingVertical="1dp"
                    android:background="#66000000"
                    android:textColor="#CCFFFFFF"
                    android:textSize="9sp"
                    android:fontFamily="sans-serif-medium"
                    android:text="REAR" />
            </FrameLayout>

            <FrameLayout
                android:id="@+id/camCellLeft"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:foreground="?attr/selectableItemBackground">

                <View
                    android:id="@+id/camActiveLeft"
                    android:layout_width="3dp"
                    android:layout_height="match_parent"
                    android:layout_gravity="start"
                    android:background="@color/brand_primary"
                    android:visibility="gone" />

                <TextView
                    android:id="@+id/tvCamLabelLeft"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="bottom|center_horizontal"
                    android:layout_margin="4dp"
                    android:paddingHorizontal="4dp"
                    android:paddingVertical="1dp"
                    android:background="#66000000"
                    android:textColor="#CCFFFFFF"
                    android:textSize="9sp"
                    android:fontFamily="sans-serif-medium"
                    android:text="LEFT" />
            </FrameLayout>

        </LinearLayout>
    </LinearLayout>

    <!--
        Top bar: back + title + meta.
        Starts GONE. Tap the large area to reveal; auto-hides after 3 s of playback.
    -->
    <LinearLayout
        android:id="@+id/topBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="12dp"
        android:background="#80000000"
        android:layout_gravity="top"
        android:visibility="gone">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_back"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Back"
            android:tint="#FFFFFF"
            android:scaleType="centerInside" />

        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:fontFamily="sans-serif-medium"
            android:maxLines="1"
            android:ellipsize="middle" />

        <TextView
            android:id="@+id/tvMeta"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#B0FFFFFF"
            android:textSize="12sp" />
    </LinearLayout>

    <!--
        Bottom controls: seekbar + play/pause + time.
        Starts GONE. Shown when top bar is revealed.
        Event timeline removed — the single seekbar is cleaner.
    -->
    <LinearLayout
        android:id="@+id/bottomControls"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_gravity="bottom"
        android:background="#CC000000"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:paddingTop="4dp"
        android:paddingBottom="8dp"
        android:visibility="gone">

        <!--
            Event detection timeline: thin 8dp strip of colored markers sitting
            directly above the seekbar, so it reads as a single integrated scrub control.
            Duration is set from mp.duration (not the JSON) to guarantee sync.
        -->
        <com.overdrive.app.ui.view.EventTimelineView
            android:id="@+id/eventTimeline"
            android:layout_width="match_parent"
            android:layout_height="16dp"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginBottom="2dp" />

        <SeekBar
            android:id="@+id/seekBar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:progressTint="#6C63FF"
            android:thumbTint="#6C63FF"
            android:progressBackgroundTint="#55FFFFFF" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="4dp"
            android:paddingEnd="4dp">

            <!-- Skip-previous: hidden when no playlist or already at first item -->
            <ImageButton
                android:id="@+id/btnPrev"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_skip_prev"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Previous video"
                android:tint="#FFFFFF"
                android:scaleType="centerInside"
                android:visibility="gone" />

            <ImageButton
                android:id="@+id/btnPlayPause"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@android:drawable/ic_media_pause"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Play/Pause"
                android:tint="#FFFFFF"
                android:scaleType="centerInside" />

            <!-- Skip-next: hidden when no playlist or already at last item -->
            <ImageButton
                android:id="@+id/btnNext"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_skip_next"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Next video"
                android:tint="#FFFFFF"
                android:scaleType="centerInside"
                android:visibility="gone" />

            <TextView
                android:id="@+id/tvCurrentTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0:00"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:fontFamily="monospace"
                android:layout_marginStart="8dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=" / "
                android:textColor="#80FFFFFF"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/tvDuration"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="0:00"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:fontFamily="monospace" />

        </LinearLayout>
    </LinearLayout>


</FrameLayout>
