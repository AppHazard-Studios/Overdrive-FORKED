<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="12dp"
    android:background="@android:color/transparent">

    <!-- ── Row 1: Recording + Sentry ──────────────────────────────────── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:layout_marginBottom="8dp">

        <!-- ── Recording widget ──────────────────────────────────────── -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardRecording"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginEnd="4dp"
            app:cardBackgroundColor="@color/bg_surface"
            app:cardCornerRadius="14dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/card_border"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical">

                <View
                    android:layout_width="match_parent"
                    android:layout_height="3dp"
                    android:background="@drawable/gradient_brand" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:padding="12dp">

                    <!-- Header -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <ImageView
                            android:layout_width="14dp"
                            android:layout_height="14dp"
                            android:src="@drawable/ic_recording"
                            app:tint="@color/brand_primary"
                            android:contentDescription="Recording" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="7dp"
                            android:text="RECORDING"
                            android:textColor="@color/text_muted"
                            android:textSize="10sp"
                            android:fontFamily="sans-serif-medium"
                            android:letterSpacing="0.06" />

                        <TextView
                            android:id="@+id/tvRecPill"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="IDLE"
                            android:textColor="@color/text_muted"
                            android:textSize="10sp"
                            android:fontFamily="sans-serif-medium"
                            android:paddingStart="8dp"
                            android:paddingEnd="8dp"
                            android:paddingTop="3dp"
                            android:paddingBottom="3dp"
                            android:background="@drawable/status_pill_bg" />

                    </LinearLayout>

                    <!-- Primary value — vertically centred in remaining space -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center_vertical">

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="bottom">

                            <TextView
                                android:id="@+id/tvRecValueNum"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="--"
                                android:textColor="@color/text_primary"
                                android:textSize="28sp"
                                android:fontFamily="monospace"
                                android:fontWeight="700" />

                            <TextView
                                android:id="@+id/tvRecValueUnit"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text=" GB"
                                android:textColor="@color/text_muted"
                                android:textSize="13sp"
                                android:layout_marginBottom="4dp" />

                        </LinearLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="free to record"
                            android:textColor="@color/text_muted"
                            android:textSize="12sp"
                            android:layout_marginTop="1dp" />

                    </LinearLayout>

                    <!-- Footer — storage bar + detail -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <FrameLayout
                            android:id="@+id/frameRecBar"
                            android:layout_width="match_parent"
                            android:layout_height="5dp"
                            android:layout_marginBottom="6dp"
                            android:background="@color/bg_elevated">

                            <View
                                android:id="@+id/viewRecBar"
                                android:layout_width="0dp"
                                android:layout_height="5dp"
                                android:background="@drawable/gradient_brand" />

                        </FrameLayout>

                        <TextView
                            android:id="@+id/tvRecDetail"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="-- used  ·  -- total"
                            android:textColor="@color/text_muted"
                            android:textSize="11sp" />

                    </LinearLayout>

                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ── Sentry widget ──────────────────────────────────────────── -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardSurveillance"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginStart="4dp"
            app:cardBackgroundColor="@color/bg_surface"
            app:cardCornerRadius="14dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/card_border"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical">

                <View
                    android:id="@+id/viewSentryAccent"
                    android:layout_width="match_parent"
                    android:layout_height="3dp"
                    android:background="@drawable/gradient_brand" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:padding="12dp">

                    <!-- Header -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <ImageView
                            android:layout_width="14dp"
                            android:layout_height="14dp"
                            android:src="@drawable/ic_sentry"
                            app:tint="@color/brand_primary"
                            android:contentDescription="Sentry" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="7dp"
                            android:text="SENTRY"
                            android:textColor="@color/text_muted"
                            android:textSize="10sp"
                            android:fontFamily="sans-serif-medium"
                            android:letterSpacing="0.06" />

                        <TextView
                            android:id="@+id/tvSurvPill"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="--"
                            android:textColor="@color/text_muted"
                            android:textSize="10sp"
                            android:fontFamily="sans-serif-medium"
                            android:paddingStart="8dp"
                            android:paddingEnd="8dp"
                            android:paddingTop="3dp"
                            android:paddingBottom="3dp"
                            android:background="@drawable/status_pill_bg" />

                    </LinearLayout>

                    <!-- Primary — event count -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center_vertical">

                        <TextView
                            android:id="@+id/tvSurvEventsNum"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="--"
                            android:textColor="@color/text_primary"
                            android:textSize="28sp"
                            android:fontFamily="monospace"
                            android:fontWeight="700" />

                        <TextView
                            android:id="@+id/tvSurvEventsSub"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="events today"
                            android:textColor="@color/text_muted"
                            android:textSize="12sp"
                            android:layout_marginTop="1dp" />

                    </LinearLayout>

                    <!-- Footer — last detection -->
                    <TextView
                        android:id="@+id/tvSurvLastDet"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="--"
                        android:textColor="@color/text_muted"
                        android:textSize="11sp"
                        android:singleLine="true"
                        android:ellipsize="end" />

                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>

    <!-- ── Row 2: System + Vehicle ────────────────────────────────────── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal">

        <!-- ── System widget ──────────────────────────────────────────── -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardDaemonHealth"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginEnd="4dp"
            app:cardBackgroundColor="@color/bg_surface"
            app:cardCornerRadius="14dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/card_border"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical">

                <View
                    android:id="@+id/viewSystemAccent"
                    android:layout_width="match_parent"
                    android:layout_height="3dp"
                    android:background="@drawable/gradient_brand" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:padding="12dp">

                    <!-- Header -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="10dp">

                        <ImageView
                            android:layout_width="14dp"
                            android:layout_height="14dp"
                            android:src="@drawable/ic_performance"
                            app:tint="@color/brand_primary"
                            android:contentDescription="System" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="7dp"
                            android:text="SYSTEM"
                            android:textColor="@color/text_muted"
                            android:textSize="10sp"
                            android:fontFamily="sans-serif-medium"
                            android:letterSpacing="0.06" />

                        <TextView
                            android:id="@+id/tvDaemonCount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="--/5"
                            android:textColor="@color/brand_primary"
                            android:textSize="14sp"
                            android:fontFamily="monospace"
                            android:fontWeight="700" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text=" daemons"
                            android:textColor="@color/text_muted"
                            android:textSize="11sp" />

                    </LinearLayout>

                    <!-- Metric rows — vertically centred in remaining space -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center_vertical">

                        <!-- CPU -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="4dp">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="CPU"
                                android:textColor="@color/text_secondary"
                                android:textSize="11sp"
                                android:fontFamily="sans-serif-medium" />

                            <TextView
                                android:id="@+id/tvCpuVal"
                                android:layout_width="40dp"
                                android:layout_height="wrap_content"
                                android:text="--%"
                                android:textColor="@color/text_primary"
                                android:textSize="14sp"
                                android:fontFamily="monospace"
                                android:gravity="end" />

                        </LinearLayout>

                        <FrameLayout
                            android:id="@+id/frameCpuBar"
                            android:layout_width="match_parent"
                            android:layout_height="5dp"
                            android:layout_marginBottom="10dp"
                            android:background="@color/bg_elevated">

                            <View
                                android:id="@+id/viewCpuBar"
                                android:layout_width="0dp"
                                android:layout_height="5dp"
                                android:background="@drawable/gradient_brand" />

                        </FrameLayout>

                        <!-- GPU -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="4dp">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="GPU"
                                android:textColor="@color/text_secondary"
                                android:textSize="11sp"
                                android:fontFamily="sans-serif-medium" />

                            <TextView
                                android:id="@+id/tvGpuVal"
                                android:layout_width="40dp"
                                android:layout_height="wrap_content"
                                android:text="--%"
                                android:textColor="@color/text_primary"
                                android:textSize="14sp"
                                android:fontFamily="monospace"
                                android:gravity="end" />

                        </LinearLayout>

                        <FrameLayout
                            android:id="@+id/frameGpuBar"
                            android:layout_width="match_parent"
                            android:layout_height="5dp"
                            android:layout_marginBottom="10dp"
                            android:background="@color/bg_elevated">

                            <View
                                android:id="@+id/viewGpuBar"
                                android:layout_width="0dp"
                                android:layout_height="5dp"
                                android:background="@drawable/gradient_brand" />

                        </FrameLayout>

                        <!-- MEM -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="4dp">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="MEM"
                                android:textColor="@color/text_secondary"
                                android:textSize="11sp"
                                android:fontFamily="sans-serif-medium" />

                            <TextView
                                android:id="@+id/tvMemVal"
                                android:layout_width="40dp"
                                android:layout_height="wrap_content"
                                android:text="--%"
                                android:textColor="@color/text_primary"
                                android:textSize="14sp"
                                android:fontFamily="monospace"
                                android:gravity="end" />

                        </LinearLayout>

                        <FrameLayout
                            android:id="@+id/frameMemBar"
                            android:layout_width="match_parent"
                            android:layout_height="5dp"
                            android:background="@color/bg_elevated">

                            <View
                                android:id="@+id/viewMemBar"
                                android:layout_width="0dp"
                                android:layout_height="5dp"
                                android:background="@drawable/gradient_brand" />

                        </FrameLayout>

                    </LinearLayout>

                    <!-- Footer — daemon dots -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:background="@color/card_border"
                            android:layout_marginTop="10dp"
                            android:layout_marginBottom="8dp" />

                        <LinearLayout
                            android:id="@+id/layoutDaemonDots"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal" />

                    </LinearLayout>

                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ── Vehicle widget ─────────────────────────────────────────── -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardVehicle"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginStart="4dp"
            app:cardBackgroundColor="@color/bg_surface"
            app:cardCornerRadius="14dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/card_border"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical">

                <View
                    android:id="@+id/viewVehicleAccent"
                    android:layout_width="match_parent"
                    android:layout_height="3dp"
                    android:background="@drawable/gradient_brand" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:padding="12dp">

                    <!-- Header -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <ImageView
                            android:layout_width="14dp"
                            android:layout_height="14dp"
                            android:src="@drawable/ic_performance"
                            app:tint="@color/brand_primary"
                            android:contentDescription="Vehicle" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="7dp"
                            android:text="VEHICLE"
                            android:textColor="@color/text_muted"
                            android:textSize="10sp"
                            android:fontFamily="sans-serif-medium"
                            android:letterSpacing="0.06" />

                        <TextView
                            android:id="@+id/tvThermalBadge"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="--"
                            android:textColor="@color/text_muted"
                            android:textSize="10sp"
                            android:fontFamily="sans-serif-medium"
                            android:paddingStart="8dp"
                            android:paddingEnd="8dp"
                            android:paddingTop="3dp"
                            android:paddingBottom="3dp"
                            android:background="@drawable/status_pill_bg" />

                    </LinearLayout>

                    <!-- Primary — 12V voltage -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center_vertical">

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="bottom">

                            <TextView
                                android:id="@+id/tvVehicleVoltNum"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="--"
                                android:textColor="@color/status_success"
                                android:textSize="28sp"
                                android:fontFamily="monospace"
                                android:fontWeight="700" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text=" V"
                                android:textColor="@color/text_muted"
                                android:textSize="13sp"
                                android:layout_marginBottom="4dp" />

                        </LinearLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="12V Battery"
                            android:textColor="@color/text_muted"
                            android:textSize="12sp"
                            android:layout_marginTop="1dp" />

                        <!-- SOC + Range row -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginTop="12dp">

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical">

                                <TextView
                                    android:id="@+id/tvStatSoc"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="--%"
                                    android:textColor="@color/status_success"
                                    android:textSize="18sp"
                                    android:fontFamily="monospace"
                                    android:fontWeight="600" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="SOC"
                                    android:textColor="@color/text_muted"
                                    android:textSize="10sp"
                                    android:fontFamily="sans-serif-medium"
                                    android:letterSpacing="0.04"
                                    android:layout_marginTop="1dp" />

                            </LinearLayout>

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical">

                                <TextView
                                    android:id="@+id/tvStatRange"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="-- km"
                                    android:textColor="@color/text_primary"
                                    android:textSize="18sp"
                                    android:fontFamily="monospace"
                                    android:fontWeight="600" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="RANGE"
                                    android:textColor="@color/text_muted"
                                    android:textSize="10sp"
                                    android:fontFamily="sans-serif-medium"
                                    android:letterSpacing="0.04"
                                    android:layout_marginTop="1dp" />

                            </LinearLayout>

                        </LinearLayout>

                    </LinearLayout>

                    <!-- Footer — today's trip -->
                    <LinearLayout
                        android:id="@+id/layoutTodayTrip"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:visibility="gone">

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:background="@color/card_border"
                            android:layout_marginBottom="8dp" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="TODAY"
                                android:textColor="@color/text_muted"
                                android:textSize="10sp"
                                android:fontFamily="sans-serif-medium"
                                android:letterSpacing="0.05" />

                            <View
                                android:layout_width="0dp"
                                android:layout_height="1dp"
                                android:layout_weight="1" />

                            <TextView
                                android:id="@+id/tvTodayScore"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="--"
                                android:textColor="@color/status_success"
                                android:textSize="14sp"
                                android:fontFamily="monospace"
                                android:fontWeight="700" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text=" · "
                                android:textColor="@color/text_muted"
                                android:textSize="12sp" />

                            <TextView
                                android:id="@+id/tvTodayDistance"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="-- km"
                                android:textColor="@color/text_secondary"
                                android:textSize="13sp"
                                android:fontFamily="monospace" />

                        </LinearLayout>

                    </LinearLayout>

                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>

</LinearLayout>
