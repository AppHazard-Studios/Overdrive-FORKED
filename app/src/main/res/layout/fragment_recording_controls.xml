<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/scrollViewRecordingControls"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_base"
    android:fillViewport="true"
    android:clipToPadding="false">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp"
        android:paddingBottom="80dp">

        <!-- Row 1: Recording Mode (left) + Quality (right) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">

            <!-- LEFT: Recording Mode -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                app:cardBackgroundColor="@color/bg_surface"
                app:cardCornerRadius="20dp"
                app:strokeColor="@color/card_border"
                app:strokeWidth="1dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        android:text="RECORDING MODE"
                        android:textColor="#80FFFFFF"
                        android:textSize="11sp"
                        android:letterSpacing="0.12"
                        android:fontFamily="sans-serif-medium" />

                    <RadioGroup
                        android:id="@+id/radioGroupRecordingMode"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">

                        <com.google.android.material.radiobutton.MaterialRadioButton
                            android:id="@+id/radioModeNone"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:checked="true"
                            android:paddingVertical="10dp"
                            android:text="@string/recording_mode_none_full"
                            android:textColor="@color/text_primary"
                            android:textSize="14sp" />

                        <com.google.android.material.radiobutton.MaterialRadioButton
                            android:id="@+id/radioModeContinuous"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:paddingVertical="10dp"
                            android:text="@string/recording_mode_continuous_full"
                            android:textColor="@color/text_primary"
                            android:textSize="14sp" />

                        <com.google.android.material.radiobutton.MaterialRadioButton
                            android:id="@+id/radioModeDriveMode"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:paddingVertical="10dp"
                            android:text="@string/recording_mode_drive_full"
                            android:textColor="@color/text_primary"
                            android:textSize="14sp" />

                        <com.google.android.material.radiobutton.MaterialRadioButton
                            android:id="@+id/radioModeProximityGuard"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:paddingVertical="10dp"
                            android:text="@string/recording_mode_proximity_full"
                            android:textColor="@color/text_primary"
                            android:textSize="14sp" />

                    </RadioGroup>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- RIGHT: Quality + Telemetry -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                app:cardBackgroundColor="@color/bg_surface"
                app:cardCornerRadius="20dp"
                app:strokeColor="@color/card_border"
                app:strokeWidth="1dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        android:text="QUALITY"
                        android:textColor="#80FFFFFF"
                        android:textSize="11sp"
                        android:letterSpacing="0.12"
                        android:fontFamily="sans-serif-medium" />

                    <!-- Recording Quality -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="6dp"
                        android:text="@string/quality_label"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp" />

                    <com.google.android.material.button.MaterialButtonToggleGroup
                        android:id="@+id/toggleRecordingQuality"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="14dp"
                        app:singleSelection="true"
                        app:selectionRequired="true">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnRecQualityLow"
                            style="@style/Widget.Overdrive.Button.Toggle"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Low" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnRecQualityReduced"
                            style="@style/Widget.Overdrive.Button.Toggle"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Reduced" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnRecQualityNormal"
                            style="@style/Widget.Overdrive.Button.Toggle"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Normal" />

                    </com.google.android.material.button.MaterialButtonToggleGroup>

                    <!-- Bitrate -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="6dp"
                        android:text="@string/bitrate_label"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp" />

                    <com.google.android.material.button.MaterialButtonToggleGroup
                        android:id="@+id/toggleRecordingBitrate"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="14dp"
                        app:singleSelection="true"
                        app:selectionRequired="true">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnBitrateLow"
                            style="@style/Widget.Overdrive.Button.Toggle"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Low" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnBitrateMedium"
                            style="@style/Widget.Overdrive.Button.Toggle"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Med" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnBitrateHigh"
                            style="@style/Widget.Overdrive.Button.Toggle"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="High" />

                    </com.google.android.material.button.MaterialButtonToggleGroup>

                    <!-- Codec -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="6dp"
                        android:text="@string/codec_label"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp" />

                    <com.google.android.material.button.MaterialButtonToggleGroup
                        android:id="@+id/toggleVideoCodec"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:singleSelection="true"
                        app:selectionRequired="true">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnCodecH264"
                            style="@style/Widget.Overdrive.Button.Toggle"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="H.264" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnCodecH265"
                            style="@style/Widget.Overdrive.Button.Toggle"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="H.265" />

                    </com.google.android.material.button.MaterialButtonToggleGroup>

                    <TextView
                        android:id="@+id/tvH265Warning"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:paddingHorizontal="10dp"
                        android:paddingVertical="7dp"
                        android:text="H.265: software encoding only — higher CPU load"
                        android:textColor="#FFF59E0B"
                        android:textSize="12sp"
                        android:background="@drawable/bg_warning_pill"
                        android:visibility="gone" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginTop="14dp"
                        android:layout_marginBottom="14dp"
                        android:background="@color/divider" />

                    <!-- Telemetry Overlay -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Telemetry Overlay"
                                android:textColor="@color/text_primary"
                                android:textSize="14sp"
                                android:fontFamily="sans-serif-medium" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:text="Speed, gear, pedals on video"
                                android:textColor="@color/text_muted"
                                android:textSize="12sp" />

                        </LinearLayout>

                        <com.google.android.material.switchmaterial.SwitchMaterial
                            android:id="@+id/switchTelemetryOverlay"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content" />

                    </LinearLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>

        <!-- Proximity Guard Settings — shown when Proximity Guard mode is selected -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardProximitySettings"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:visibility="gone"
            app:cardBackgroundColor="@color/bg_surface"
            app:cardCornerRadius="20dp"
            app:strokeColor="@color/card_border"
            app:strokeWidth="1dp"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:text="PROXIMITY GUARD"
                    android:textColor="#80FFFFFF"
                    android:textSize="11sp"
                    android:letterSpacing="0.12"
                    android:fontFamily="sans-serif-medium" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <!-- Left: Trigger level -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:paddingEnd="12dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="6dp"
                            android:text="@string/proximity_trigger_label"
                            android:textColor="@color/text_secondary"
                            android:textSize="12sp" />

                        <Spinner
                            android:id="@+id/spinnerTriggerLevel"
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:layout_marginBottom="16dp"
                            android:background="@drawable/spinner_background"
                            android:paddingHorizontal="16dp" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="4dp">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="@string/proximity_pre_buffer_label"
                                android:textColor="@color/text_secondary"
                                android:textSize="12sp" />

                            <TextView
                                android:id="@+id/tvPreRecordValue"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="5s"
                                android:textColor="@color/brand_primary"
                                android:textSize="13sp"
                                android:fontFamily="sans-serif-medium" />

                        </LinearLayout>

                        <com.google.android.material.slider.Slider
                            android:id="@+id/sliderPreRecord"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:valueFrom="2"
                            android:valueTo="15"
                            android:stepSize="1"
                            android:value="5" />

                    </LinearLayout>

                    <!-- Right: Post-buffer + info note -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:paddingStart="12dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="4dp">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="@string/proximity_post_buffer_label"
                                android:textColor="@color/text_secondary"
                                android:textSize="12sp" />

                            <TextView
                                android:id="@+id/tvPostRecordValue"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="10s"
                                android:textColor="@color/brand_primary"
                                android:textSize="13sp"
                                android:fontFamily="sans-serif-medium" />

                        </LinearLayout>

                        <com.google.android.material.slider.Slider
                            android:id="@+id/sliderPostRecord"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="12dp"
                            android:valueFrom="5"
                            android:valueTo="30"
                            android:stepSize="1"
                            android:value="10" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="@color/bg_elevated"
                            android:padding="10dp"
                            android:text="@string/proximity_continuation_info"
                            android:textColor="@color/text_secondary"
                            android:textSize="11sp" />

                    </LinearLayout>

                </LinearLayout>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- Storage Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardBackgroundColor="@color/bg_surface"
            app:cardCornerRadius="20dp"
            app:strokeColor="@color/card_border"
            app:strokeWidth="1dp"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:text="STORAGE"
                    android:textColor="#80FFFFFF"
                    android:textSize="11sp"
                    android:letterSpacing="0.12"
                    android:fontFamily="sans-serif-medium" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <!-- Left: Location toggle + SD status + path -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:paddingEnd="12dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="6dp"
                            android:text="Location"
                            android:textColor="@color/text_secondary"
                            android:textSize="12sp" />

                        <com.google.android.material.button.MaterialButtonToggleGroup
                            android:id="@+id/toggleRecordingsStorage"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="8dp"
                            app:singleSelection="true"
                            app:selectionRequired="true">

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnStorageInternal"
                                style="@style/Widget.Overdrive.Button.Toggle"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Internal"
                                android:textSize="12sp" />

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnStorageSdCard"
                                style="@style/Widget.Overdrive.Button.Toggle"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="SD Card"
                                android:textSize="12sp" />

                        </com.google.android.material.button.MaterialButtonToggleGroup>

                        <LinearLayout
                            android:id="@+id/sdCardStatusLayout"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="8dp"
                            android:visibility="gone">

                            <View
                                android:id="@+id/sdCardStatusDot"
                                android:layout_width="8dp"
                                android:layout_height="8dp"
                                android:background="@drawable/status_dot_offline" />

                            <TextView
                                android:id="@+id/tvSdCardStatus"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="8dp"
                                android:text="SD Card: Not detected"
                                android:textColor="@color/text_muted"
                                android:textSize="12sp" />

                        </LinearLayout>

                        <TextView
                            android:id="@+id/tvStoragePathInfo"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/storage_path_info"
                            android:textColor="@color/text_muted"
                            android:textSize="11sp" />

                    </LinearLayout>

                    <!-- Right: Usage bar + limit slider -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:paddingStart="12dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="6dp"
                            android:text="@string/storage_usage_label"
                            android:textColor="@color/text_secondary"
                            android:textSize="12sp" />

                        <FrameLayout
                            android:layout_width="match_parent"
                            android:layout_height="6dp"
                            android:background="@color/bg_elevated">

                            <View
                                android:id="@+id/storageBarFill"
                                android:layout_width="0dp"
                                android:layout_height="match_parent"
                                android:background="@color/brand_primary" />

                        </FrameLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:layout_marginBottom="14dp"
                            android:orientation="horizontal">

                            <TextView
                                android:id="@+id/tvStorageUsed"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="-- used"
                                android:textColor="@color/text_secondary"
                                android:textSize="12sp" />

                            <TextView
                                android:id="@+id/tvStorageLimit"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:gravity="end"
                                android:text="-- limit"
                                android:textColor="@color/text_secondary"
                                android:textSize="12sp" />

                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="4dp">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="@string/storage_limit_label"
                                android:textColor="@color/text_secondary"
                                android:textSize="12sp" />

                            <TextView
                                android:id="@+id/tvRecordingsLimitValue"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="500 MB"
                                android:textColor="@color/brand_primary"
                                android:textSize="13sp"
                                android:fontFamily="sans-serif-medium" />

                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical">

                            <TextView
                                android:id="@+id/tvStorageMinLabel"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="100MB"
                                android:textColor="@color/text_muted"
                                android:textSize="11sp" />

                            <com.google.android.material.slider.Slider
                                android:id="@+id/sliderRecordingsLimit"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:valueFrom="100"
                                android:valueTo="1000"
                                android:stepSize="100"
                                android:value="500" />

                            <TextView
                                android:id="@+id/tvStorageMaxLabel"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="1000MB"
                                android:textColor="@color/text_muted"
                                android:textSize="11sp" />

                        </LinearLayout>

                    </LinearLayout>

                </LinearLayout>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- CDR Cleanup Card — shown when SD card is selected -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardCdrCleanup"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:visibility="gone"
            app:cardBackgroundColor="@color/bg_surface"
            app:cardCornerRadius="20dp"
            app:strokeColor="@color/card_border"
            app:strokeWidth="1dp"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- Header -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="BYD DASHCAM CLEANUP"
                        android:textColor="#80FFFFFF"
                        android:textSize="11sp"
                        android:letterSpacing="0.12"
                        android:fontFamily="sans-serif-medium" />

                    <TextView
                        android:id="@+id/tvCdrCleanupBadge"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="12dp"
                        android:background="@drawable/status_indicator"
                        android:paddingHorizontal="8dp"
                        android:paddingVertical="2dp"
                        android:text="OFF"
                        android:textColor="@color/text_muted"
                        android:textSize="10sp" />

                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switchCdrCleanup"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content" />

                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <!-- Left: CDR stats + clean button -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:paddingEnd="12dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginBottom="12dp">

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="CDR Usage"
                                    android:textColor="@color/text_muted"
                                    android:textSize="11sp" />

                                <TextView
                                    android:id="@+id/tvCdrUsage"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="--"
                                    android:textColor="@color/text_primary"
                                    android:textSize="14sp"
                                    android:fontFamily="sans-serif-medium" />

                            </LinearLayout>

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Files"
                                    android:textColor="@color/text_muted"
                                    android:textSize="11sp" />

                                <TextView
                                    android:id="@+id/tvCdrFileCount"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="--"
                                    android:textColor="@color/text_primary"
                                    android:textSize="14sp"
                                    android:fontFamily="sans-serif-medium" />

                            </LinearLayout>

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Deletable"
                                    android:textColor="@color/text_muted"
                                    android:textSize="11sp" />

                                <TextView
                                    android:id="@+id/tvCdrDeletable"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="--"
                                    android:textColor="@color/status_error"
                                    android:textSize="14sp"
                                    android:fontFamily="sans-serif-medium" />

                            </LinearLayout>

                        </LinearLayout>

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnCdrCleanupNow"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Clean Up Now"
                            android:textColor="@color/status_error"
                            app:strokeColor="@color/status_error"
                            app:cornerRadius="8dp" />

                    </LinearLayout>

                    <!-- Right: Threshold sliders -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:paddingStart="12dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="4dp">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Reserved for Overdrive"
                                android:textColor="@color/text_secondary"
                                android:textSize="12sp" />

                            <TextView
                                android:id="@+id/tvCdrReservedValue"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="2 GB"
                                android:textColor="@color/brand_primary"
                                android:textSize="13sp"
                                android:fontFamily="sans-serif-medium" />

                        </LinearLayout>

                        <com.google.android.material.slider.Slider
                            android:id="@+id/sliderCdrReserved"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="12dp"
                            android:valueFrom="500"
                            android:valueTo="5000"
                            android:stepSize="500"
                            android:value="2000" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="4dp">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Protect Recent Files"
                                android:textColor="@color/text_secondary"
                                android:textSize="12sp" />

                            <TextView
                                android:id="@+id/tvCdrProtectedValue"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="24h"
                                android:textColor="@color/brand_primary"
                                android:textSize="13sp"
                                android:fontFamily="sans-serif-medium" />

                        </LinearLayout>

                        <com.google.android.material.slider.Slider
                            android:id="@+id/sliderCdrProtected"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:valueFrom="1"
                            android:valueTo="72"
                            android:stepSize="1"
                            android:value="24" />

                    </LinearLayout>

                </LinearLayout>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- Apply Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnApplyQuality"
            style="@style/Widget.Overdrive.Button"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="4dp"
            android:enabled="false"
            android:text="Apply Settings"
            app:cornerRadius="12dp" />

    </LinearLayout>

</ScrollView>
