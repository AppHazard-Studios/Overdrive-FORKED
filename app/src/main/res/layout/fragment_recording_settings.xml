<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_base"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <!-- ── Two-column main row ───────────────────────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <!-- ── Left column ────────────────────────────────────────── -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                android:orientation="vertical">

                <!-- Recording Mode card -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardBackgroundColor="@color/bg_surface"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp"
                    app:strokeColor="@color/card_border"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="14dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="RECORDING MODE"
                            android:textColor="@color/text_muted"
                            android:textSize="10sp"
                            android:fontFamily="sans-serif-medium"
                            android:letterSpacing="0.08"
                            android:layout_marginBottom="10dp" />

                        <com.google.android.material.button.MaterialButtonToggleGroup
                            android:id="@+id/toggleMode"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            style="@style/Widget.Overdrive.ButtonToggleGroup">

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnModeNone"
                                android:layout_width="0dp"
                                android:layout_height="36dp"
                                android:layout_weight="1"
                                android:text="Off"
                                style="@style/Widget.Overdrive.Button.Toggle" />

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnModeContinuous"
                                android:layout_width="0dp"
                                android:layout_height="36dp"
                                android:layout_weight="1"
                                android:text="Always On"
                                style="@style/Widget.Overdrive.Button.Toggle" />

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnModeAccOnly"
                                android:layout_width="0dp"
                                android:layout_height="36dp"
                                android:layout_weight="1"
                                android:text="ACC Only"
                                style="@style/Widget.Overdrive.Button.Toggle" />

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnModeProximity"
                                android:layout_width="0dp"
                                android:layout_height="36dp"
                                android:layout_weight="1"
                                android:text="Proximity"
                                style="@style/Widget.Overdrive.Button.Toggle" />

                        </com.google.android.material.button.MaterialButtonToggleGroup>

                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Video Quality card -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    app:cardBackgroundColor="@color/bg_surface"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp"
                    app:strokeColor="@color/card_border"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="14dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="VIDEO QUALITY"
                            android:textColor="@color/text_muted"
                            android:textSize="10sp"
                            android:fontFamily="sans-serif-medium"
                            android:letterSpacing="0.08"
                            android:layout_marginBottom="10dp" />

                        <!-- Quality + Codec row -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginBottom="8dp">

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:layout_marginEnd="8dp"
                                android:orientation="vertical">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Quality"
                                    android:textColor="@color/text_secondary"
                                    android:textSize="12sp"
                                    android:layout_marginBottom="6dp" />

                                <com.google.android.material.button.MaterialButtonToggleGroup
                                    android:id="@+id/toggleQuality"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    style="@style/Widget.Overdrive.ButtonToggleGroup">

                                    <com.google.android.material.button.MaterialButton
                                        android:id="@+id/btnQualityNormal"
                                        android:layout_width="0dp"
                                        android:layout_height="34dp"
                                        android:layout_weight="1"
                                        android:text="Full"
                                        style="@style/Widget.Overdrive.Button.Toggle" />

                                    <com.google.android.material.button.MaterialButton
                                        android:id="@+id/btnQualityHigh"
                                        android:layout_width="0dp"
                                        android:layout_height="34dp"
                                        android:layout_weight="1"
                                        android:text="Reduced"
                                        style="@style/Widget.Overdrive.Button.Toggle" />

                                </com.google.android.material.button.MaterialButtonToggleGroup>
                            </LinearLayout>

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Codec"
                                    android:textColor="@color/text_secondary"
                                    android:textSize="12sp"
                                    android:layout_marginBottom="6dp" />

                                <com.google.android.material.button.MaterialButtonToggleGroup
                                    android:id="@+id/toggleCodec"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    style="@style/Widget.Overdrive.ButtonToggleGroup">

                                    <com.google.android.material.button.MaterialButton
                                        android:id="@+id/btnCodecH264"
                                        android:layout_width="0dp"
                                        android:layout_height="34dp"
                                        android:layout_weight="1"
                                        android:text="H.264"
                                        style="@style/Widget.Overdrive.Button.Toggle" />

                                    <com.google.android.material.button.MaterialButton
                                        android:id="@+id/btnCodecH265"
                                        android:layout_width="0dp"
                                        android:layout_height="34dp"
                                        android:layout_weight="1"
                                        android:text="H.265"
                                        style="@style/Widget.Overdrive.Button.Toggle" />

                                </com.google.android.material.button.MaterialButtonToggleGroup>
                            </LinearLayout>

                        </LinearLayout>

                        <!-- Bitrate row -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Bitrate"
                            android:textColor="@color/text_secondary"
                            android:textSize="12sp"
                            android:layout_marginBottom="6dp" />

                        <com.google.android.material.button.MaterialButtonToggleGroup
                            android:id="@+id/toggleBitrate"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="8dp"
                            style="@style/Widget.Overdrive.ButtonToggleGroup">

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnBitrateLow"
                                android:layout_width="0dp"
                                android:layout_height="34dp"
                                android:layout_weight="1"
                                android:text="Low"
                                style="@style/Widget.Overdrive.Button.Toggle" />

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnBitrateMedium"
                                android:layout_width="0dp"
                                android:layout_height="34dp"
                                android:layout_weight="1"
                                android:text="Medium"
                                style="@style/Widget.Overdrive.Button.Toggle" />

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnBitrateHigh"
                                android:layout_width="0dp"
                                android:layout_height="34dp"
                                android:layout_weight="1"
                                android:text="High"
                                style="@style/Widget.Overdrive.Button.Toggle" />

                        </com.google.android.material.button.MaterialButtonToggleGroup>

                        <!-- Streaming quality row -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Streaming Quality"
                            android:textColor="@color/text_secondary"
                            android:textSize="12sp"
                            android:layout_marginBottom="6dp" />

                        <com.google.android.material.button.MaterialButtonToggleGroup
                            android:id="@+id/toggleStreaming"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            style="@style/Widget.Overdrive.ButtonToggleGroup">

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnStreamingLq"
                                android:layout_width="0dp"
                                android:layout_height="34dp"
                                android:layout_weight="1"
                                android:text="LQ"
                                style="@style/Widget.Overdrive.Button.Toggle" />

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnStreamingMq"
                                android:layout_width="0dp"
                                android:layout_height="34dp"
                                android:layout_weight="1"
                                android:text="MQ"
                                style="@style/Widget.Overdrive.Button.Toggle" />

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnStreamingHq"
                                android:layout_width="0dp"
                                android:layout_height="34dp"
                                android:layout_weight="1"
                                android:text="HQ"
                                style="@style/Widget.Overdrive.Button.Toggle" />

                        </com.google.android.material.button.MaterialButtonToggleGroup>

                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>

            <!-- ── Right column ───────────────────────────────────────── -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                android:orientation="vertical">

                <!-- Storage card -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardBackgroundColor="@color/bg_surface"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp"
                    app:strokeColor="@color/card_border"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="14dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="STORAGE"
                            android:textColor="@color/text_muted"
                            android:textSize="10sp"
                            android:fontFamily="sans-serif-medium"
                            android:letterSpacing="0.08"
                            android:layout_marginBottom="10dp" />

                        <!-- Storage type toggle -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Location"
                            android:textColor="@color/text_secondary"
                            android:textSize="12sp"
                            android:layout_marginBottom="6dp" />

                        <com.google.android.material.button.MaterialButtonToggleGroup
                            android:id="@+id/toggleStorageType"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="4dp"
                            style="@style/Widget.Overdrive.ButtonToggleGroup">

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnStorageInternal"
                                android:layout_width="0dp"
                                android:layout_height="34dp"
                                android:layout_weight="1"
                                android:text="Internal"
                                style="@style/Widget.Overdrive.Button.Toggle" />

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnStorageSdCard"
                                android:layout_width="0dp"
                                android:layout_height="34dp"
                                android:layout_weight="1"
                                android:text="SD Card"
                                style="@style/Widget.Overdrive.Button.Toggle" />

                        </com.google.android.material.button.MaterialButtonToggleGroup>

                        <!-- SD card status -->
                        <TextView
                            android:id="@+id/tvSdCardStatus"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="SD Card: Not detected"
                            android:textColor="@color/text_muted"
                            android:textSize="11sp"
                            android:layout_marginBottom="10dp"
                            android:layout_marginTop="3dp" />

                        <!-- Storage limit slider -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="2dp">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Recording Limit"
                                android:textColor="@color/text_secondary"
                                android:textSize="12sp" />

                            <TextView
                                android:id="@+id/tvLimitValue"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="500 MB"
                                android:textColor="@color/brand_primary"
                                android:textSize="13sp"
                                android:fontFamily="sans-serif-medium" />

                        </LinearLayout>

                        <com.google.android.material.slider.Slider
                            android:id="@+id/sliderLimit"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:valueFrom="100"
                            android:valueTo="100000"
                            android:value="500"
                            android:stepSize="100"
                            style="@style/Widget.Overdrive.Slider"
                            android:layout_marginBottom="8dp" />

                        <!-- Usage bar -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="4dp">

                            <TextView
                                android:id="@+id/tvStorageUsed"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="-- used"
                                android:textColor="@color/text_secondary"
                                android:textSize="11sp" />

                            <TextView
                                android:id="@+id/tvStorageLimit"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="-- limit"
                                android:textColor="@color/text_muted"
                                android:textSize="11sp" />

                        </LinearLayout>

                        <FrameLayout
                            android:layout_width="match_parent"
                            android:layout_height="4dp"
                            android:background="@color/bg_elevated"
                            android:layout_marginBottom="6dp">

                            <View
                                android:id="@+id/storageBarFill"
                                android:layout_width="0dp"
                                android:layout_height="match_parent"
                                android:background="@color/brand_primary" />

                        </FrameLayout>

                        <TextView
                            android:id="@+id/tvStoragePath"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text=""
                            android:textColor="@color/text_muted"
                            android:textSize="11sp" />

                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Telemetry Overlay card -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    app:cardBackgroundColor="@color/bg_surface"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp"
                    app:strokeColor="@color/card_border"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:padding="14dp"
                        android:gravity="center_vertical">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Telemetry Overlay"
                                android:textColor="@color/text_primary"
                                android:textSize="14sp"
                                android:fontFamily="sans-serif-medium" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Speed, gear, and pedal data on recordings"
                                android:textColor="@color/text_muted"
                                android:textSize="12sp" />

                        </LinearLayout>

                        <com.google.android.material.switchmaterial.SwitchMaterial
                            android:id="@+id/switchTelemetry"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            style="@style/Widget.Overdrive.Switch" />

                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Apply button -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:gravity="end">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnApply"
                        android:layout_width="160dp"
                        android:layout_height="44dp"
                        android:text="Apply Settings"
                        android:enabled="false"
                        app:backgroundTint="@color/brand_primary"
                        android:textColor="@color/bg_base"
                        app:cornerRadius="12dp"
                        android:fontFamily="sans-serif-medium" />

                </LinearLayout>

            </LinearLayout>

        </LinearLayout>

        <!-- ── Proximity Guard card (conditional) ───────────────────── -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardProximityGuard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:visibility="gone"
            app:cardBackgroundColor="@color/bg_surface"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/card_border"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="14dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="PROXIMITY GUARD SETTINGS"
                    android:textColor="@color/text_muted"
                    android:textSize="10sp"
                    android:fontFamily="sans-serif-medium"
                    android:letterSpacing="0.08"
                    android:layout_marginBottom="10dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <!-- Trigger Level -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="16dp"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Trigger Level"
                            android:textColor="@color/text_secondary"
                            android:textSize="12sp"
                            android:layout_marginBottom="6dp" />

                        <com.google.android.material.button.MaterialButtonToggleGroup
                            android:id="@+id/toggleTriggerLevel"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            style="@style/Widget.Overdrive.ButtonToggleGroup">

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnTriggerYellow"
                                android:layout_width="0dp"
                                android:layout_height="34dp"
                                android:layout_weight="1"
                                android:text="Yellow"
                                style="@style/Widget.Overdrive.Button.Toggle" />

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnTriggerOrange"
                                android:layout_width="0dp"
                                android:layout_height="34dp"
                                android:layout_weight="1"
                                android:text="Orange"
                                style="@style/Widget.Overdrive.Button.Toggle" />

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnTriggerRed"
                                android:layout_width="0dp"
                                android:layout_height="34dp"
                                android:layout_weight="1"
                                android:text="Red"
                                style="@style/Widget.Overdrive.Button.Toggle" />

                        </com.google.android.material.button.MaterialButtonToggleGroup>

                    </LinearLayout>

                    <!-- Pre/Post record sliders -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="16dp"
                        android:orientation="vertical">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Pre-record"
                                android:textColor="@color/text_secondary"
                                android:textSize="12sp" />

                            <TextView
                                android:id="@+id/tvPreRecordValue"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="5s"
                                android:textColor="@color/brand_primary"
                                android:textSize="13sp"
                                android:fontFamily="sans-serif-medium" />

                        </LinearLayout>

                        <com.google.android.material.slider.Slider
                            android:id="@+id/sliderPreRecord"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:valueFrom="2"
                            android:valueTo="15"
                            android:value="5"
                            android:stepSize="1"
                            style="@style/Widget.Overdrive.Slider"
                            android:layout_marginBottom="4dp" />

                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Post-record"
                                android:textColor="@color/text_secondary"
                                android:textSize="12sp" />

                            <TextView
                                android:id="@+id/tvPostRecordValue"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="10s"
                                android:textColor="@color/brand_primary"
                                android:textSize="13sp"
                                android:fontFamily="sans-serif-medium" />

                        </LinearLayout>

                        <com.google.android.material.slider.Slider
                            android:id="@+id/sliderPostRecord"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:valueFrom="5"
                            android:valueTo="30"
                            android:value="10"
                            android:stepSize="1"
                            style="@style/Widget.Overdrive.Slider" />

                    </LinearLayout>

                </LinearLayout>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
</ScrollView>
