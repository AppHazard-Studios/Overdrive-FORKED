<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Base gradient -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:type="linear"
                android:angle="135"
                android:startColor="@color/bg_elevated"
                android:centerColor="@color/bg_surface"
                android:endColor="@color/bg_base" />
        </shape>
    </item>
    <!-- Subtle accent glow -->
    <item android:top="0dp" android:bottom="0dp">
        <shape android:shape="rectangle">
            <gradient
                android:type="radial"
                android:gradientRadius="200dp"
                android:centerX="0.3"
                android:centerY="0.5"
                android:startColor="#1500D4AA"
                android:endColor="@android:color/transparent" />
        </shape>
    </item>
</layer-list>
